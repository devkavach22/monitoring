# Environment Configuration for ScreenShort
# Remote Linux Server Details
REMOTE_HOST=your_server_ip
REMOTE_PORT=22
REMOTE_USER=your_username
REMOTE_PASSWORD=your_password_or_empty
SSH_KEY_PATH=path/to/your/id_rsa_if_using_key

# Remote destination base directory
# The script will append the local username automatically: /tmp/ScreenShort/username
REMOTE_BASE_DIR=/tmp/ScreenShort

# Scheduling (in minutes)
INTERVAL_MINUTES=1

# Local temporary storage
LOCAL_TEMP_DIR=temp
